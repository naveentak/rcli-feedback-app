# HMAC secret for signed web forms (must match macOS FeedbackTokenManager)
FEEDBACK_HMAC_SECRET=e6d000c262c414581bc3d28c658143ccd68072291c1834ff406f43d846b3b0d6

# CLI client
FEEDBACK_API_URL=http://localhost:8080
FEEDBACK_API_KEY=secret-rclip-key
